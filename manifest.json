{
  "manifest_version": 3,
  "name": "LinkedIn Experience ExTRACTOR",
  "version": "2.0",
  "description": "Auto-saves experience & projects from any LinkedIn profile you visit",
  "permissions": ["storage", "downloads", "activeTab", "scripting"],
  "host_permissions": ["https://www.linkedin.com/*"],
  "content_scripts": [
    {
      "matches": ["https://www.linkedin.com/in/*"],
      "js": ["content.js"],
      "run_at": "document_idle"
    }
  ],
  "action": {
    "default_popup": "popup.html",
    "default_title": "Experience ExTRACTOR"
  },
  "icons": { "16": "icon.png", "48": "icon.png", "128": "icon.png" }
}
